# Telegram credentials — copy this file to ".env" and fill in your values.
# (Load it before running, e.g.  `set -a; . ./.env; set +a`  or `export $(grep -v '^#' .env | xargs)`.)

# Bot token from @BotFather
TELEGRAM_TOKEN=123456789:AA...your-bot-token...

# Target chat/group id. Group/supergroup ids are negative (e.g. -1001234567890).
# Tip: add @RawDataBot to your group to read its chat id, then remove it.
TELEGRAM_CHAT_ID=-1001234567890

# Optional — real-time US quote via Finnhub (free tier, IEX). If unset, falls back to yfinance.
FINNHUB_TOKEN=
